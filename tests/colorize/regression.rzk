-- Lambda abstraction `\` after whitespace (regression: previously broken
-- because the rule used `\b(\\)` which did not match between space and `\`,
-- and because `#param-identifiers` could match a zero-length span and
-- collapse the enclosing begin/end region)
\ x -> x
